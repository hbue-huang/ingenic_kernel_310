config INGENIC_SFC_V2
	tristate "Ingenic series SFC driver v2"
	depends on MACH_XBURST
	help
		SFC driver version v2.0 for Ingenic series SoCs

if INGENIC_SFC_V2

choice
	prompt "sfc Mode"
	help
	  Select sfc Mode

config SPI_STANDARD_MODE
	bool "standard spi mode"
	depends on INGENIC_SFC_V2
	help
	  Say Y here to enable spi standard mode

config SPI_QUAD_MODE
	bool "quad spi mode"
	depends on INGENIC_SFC_V2
	help
	  Say Y Here to enable spi QUAD MODE
endchoice

choice
	prompt "SFC Data Mode"
	help
	  Select Data Mode

config SFC_PIO_MODE
	bool "PIO mode"
	depends on INGENIC_SFC_V2
	help
	  Say Y here to enable PIO mode

config SFC_DMA_MODE
	bool "DMA mode"
	depends on INGENIC_SFC_V2
	help
	  Say Y here to enable DMA mode

endchoice

config SFC0
	bool "Ingenic series SFC0"
	depends on INGENIC_SFC_V2
	help
		Say Y here to enable sfc 0

if SFC0
config SFC0_SPEED
    int "ingenic SFC speed in MHZ"
	range 10 100
	default 50
	depends on SFC0
	help
	    Select sfc speed.
		Examples:
			50 =>  50 MHZ
choice
	prompt "the SFC0 external memory (nor or nand)"
	help
	  Select the SFC external memory

config SFC0_V2_NORFLASH
	bool "nor"
	depends on SFC0
	select MTD_INGENIC_SFC_V2_NORFLASH

config SFC0_V2_NANDFLASH
	bool "nand"
	depends on SFC0
	select MTD_INGENIC_SFC_V2_NANDFLASH

endchoice

choice
	prompt "the SFC0 controller function pins select"
	help
	  Select the SFC0 function pins

config JZ_SFC0_PA
	bool "GPIO_PA(23 ~ 28) "
	depends on SFC0
endchoice
endif

config SFC1
	bool "Ingenic series SFC1"
	depends on INGENIC_SFC_V2
	help
		Say Y here to enable sfc 1

if SFC1
config SFC1_SPEED
    int "ingenic SFC speed in MHZ"
	range 10 100
	default 50
	depends on SFC1
	help
	    Select sfc speed.
		Examples:
			50 =>  50 MHZ
choice
	prompt "the SFC1 external memory (nor or nand)"
	help
	  Select the SFC external memory

config SFC1_V2_NORFLASH
	bool "nor"
	depends on SFC1
	select MTD_INGENIC_SFC_V2_NORFLASH

config SFC1_V2_NANDFLASH
	bool "nand"
	depends on SFC1
	select MTD_INGENIC_SFC_V2_NANDFLASH

endchoice

choice
	prompt "the SFC1 controller function pins select"
	help
	  Select the SFC1 function pins

config JZ_SFC1_PC1
	bool "GPIO_PC(2 ~ 7) "
	depends on SFC1

config JZ_SFC1_PC2
	bool "GPIO_PC(11 ~ 16)"
	depends on SFC1
endchoice

endif



config MTD_INGENIC_SFC_V2_NORFLASH
	bool "Support ingenic sfc-nor"
	depends on INGENIC_SFC_V2

if MTD_INGENIC_SFC_V2_NORFLASH

choice
	prompt "Erase block size"
	help
	Select nor flash erase block size

config ERASE_SIZE_32K
	bool "sfc-nor 32k erase block"
	depends on MTD_INGENIC_SFC_V2_NORFLASH

config ERASE_SIZE_64K
	bool "sfc-nor 64k erase block"
	depends on MTD_INGENIC_SFC_V2_NORFLASH

endchoice

config JZ_SFC_NOR_RESET
	bool "Reset nor flash in the kernel"
	depends on MTD_INGENIC_SFC_V2_NORFLASH
	help
		Reset nor flash in the kernel
endif

config MTD_INGENIC_SFC_V2_NANDFLASH
	bool "Support ingenic sfc-nand"
	depends on INGENIC_SFC_V2
	select MTD_NAND

endif

